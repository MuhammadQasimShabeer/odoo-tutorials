<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ===================== -->
    <!-- MODULE CATEGORY -->
    <!-- ===================== -->
    <record id="module_category_real_estate_brokerage" model="ir.module.category">
        <field name="name">Real Estate</field>
        <field name="description">Real Estate Management</field>
        <field name="sequence">10</field>
    </record>

    <!-- ===================== -->
    <!-- GROUP PRIVILEGE -->
    <!-- ===================== -->
    <record id="groups_privilege_real_estate" model="res.groups">
        <field name="name">Real Estate</field>
        <field name="category_id" ref="module_category_real_estate_brokerage"/>
    </record>

    <!-- ===================== -->
    <!-- AGENT GROUP -->
    <!-- ===================== -->
    <record id="estate_group_user" model="res.groups">
        <field name="name">Agent</field>
        <field name="category_id" ref="module_category_real_estate_brokerage"/>
        <field name="implied_ids" eval="[(4, ref('groups_privilege_real_estate'))]"/>
    </record>

    <!-- ===================== -->
    <!-- MANAGER GROUP -->
    <!-- ===================== -->
    <record id="estate_group_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="category_id" ref="module_category_real_estate_brokerage"/>
        <field name="implied_ids" eval="[
            (4, ref('groups_privilege_real_estate')),
            (4, ref('estate_group_user'))
        ]"/>
    </record>

    <record id="estate_property_rule_agent" model="ir.rule">
        <field name="name">Agent: own or unassigned properties</field>
        <field name="model_id" ref="model_estate_property"/>
        <field name="groups" eval="[(4, ref('estate_group_user'))]"/>
        <field name="domain_force">
            ['|', ('seller_id', '=', False), ('seller_id', '=', user.id)]
        </field>
    </record>

    <record id="estate_property_rule_manager" model="ir.rule">
        <field name="name">Manager: see all properties</field>
        <field name="model_id" ref="model_estate_property"/>
        <field name="groups" eval="[(4, ref('estate_group_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>
</odoo>