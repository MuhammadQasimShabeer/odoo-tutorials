        </record>

        <!-- Demo medicines -->
        <record id="demo_medicine_1" model="pharmacy.medicine">
            <field name="name">Paracetamol 500mg</field>
            <field name="batch_number">BATCH-001</field>
            <field name="expiry_date">2025-12-31</field>
