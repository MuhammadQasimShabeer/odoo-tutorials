<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Custom list view for sale orders -->
    <record id="pharmacy_sale_order_list_view" model="ir.ui.view">
        <field name="name">pharmacy.sale.order.list</field>
        <field name="model">sale.order</field>
        <field name="arch" type="xml">
            <list string="Orders" multi_edit="1">
                <field name="name" string="Order Reference"/>
                <field name="partner_id" string="Customer"/>
                <field name="date_order" string="Date"/>
                <field name="amount_total" string="Total" widget="monetary"/>
                <field name="state" string="Status" widget="badge"/>
                <!-- Show creator only for managers (optional) -->
                <field name="create_uid" string="Created By" groups="pharma_control_center.group_pharmacy_manager"/>
            </list>
        </field>
    </record>

    <!-- Action for orders – no explicit search view -->
    <record id="pharmacy_orders_action" model="ir.actions.act_window">
        <field name="name">📄 Orders</field>
        <field name="res_model">sale.order</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="pharmacy_sale_order_list_view"/>
        <!-- No search_view_id, use default -->
    </record>

    <!-- Menu visible to all users (no groups) -->
    <menuitem id="pharmacy_orders_menu"
              name="📄 Orders"
              parent="pharma_root_menu"
              action="pharmacy_orders_action"
              sequence="4"
              groups="pharma_control_center.group_pharmacy_patient,pharma_control_center.group_pharmacy_doctor,pharma_control_center.group_pharmacy_manager"/>
</odoo>