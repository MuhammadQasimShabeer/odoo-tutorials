<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Pivot view for sales report -->
    <record id="sales_report_pivot_view" model="ir.ui.view">
        <field name="name">sales.report.pivot</field>
        <field name="model">sale.order</field>
        <field name="arch" type="xml">
            <pivot string="Sales Report">
                <field name="date_order" type="row" interval="month"/>
                <field name="partner_id" type="row"/>
                <field name="user_id" type="row"/>
                <field name="amount_total" type="measure" string="Total Sales" widget="monetary"/>
            </pivot>
        </field>
    </record>

    <!-- Search view -->
    <record id="sales_report_search_view" model="ir.ui.view">
        <field name="name">sales.report.search</field>
        <field name="model">sale.order</field>
        <field name="arch" type="xml">
            <search>
                <field name="date_order" string="Order Date"/>
                <field name="partner_id" string="Patient"/>
                <field name="user_id" string="Doctor"/>
                <filter string="Not Cancelled" name="not_cancelled" domain="[('state', 'not in', ['cancel'])]"/>
                <group expand="0" string="Group By">
                    <filter string="Day" name="group_day" context="{'group_by': 'date_order:day'}"/>
                    <filter string="Week" name="group_week" context="{'group_by': 'date_order:week'}"/>
                    <filter string="Month" name="group_month" context="{'group_by': 'date_order:month'}"/>
                    <filter string="Patient" name="group_patient" context="{'group_by': 'partner_id'}"/>
                    <filter string="Doctor" name="group_doctor" context="{'group_by': 'user_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Window action -->
    <record id="sales_report_action" model="ir.actions.act_window">
        <field name="name">Sales Report</field>
        <field name="res_model">sale.order</field>
        <field name="view_mode">pivot</field>
        <field name="view_id" ref="sales_report_pivot_view"/>
        <field name="search_view_id" ref="sales_report_search_view"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No sales orders yet. Orders will appear here after checkout.
            </p>
        </field>
    </record>

    <!-- Menu -->
    <menuitem id="analytics_root_menu"
              name="📊 Analytics"
              parent="pharma_root_menu"
              sequence="50"/>

    <menuitem id="sales_report_menu"
              name="Sales Report"
              parent="analytics_root_menu"
              action="sales_report_action"
              sequence="10"/>
</odoo>